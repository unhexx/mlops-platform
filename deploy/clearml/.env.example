# Public hostname or IP address used by operators and SDK clients.
CLEARML_HOST=localhost

# Published ports on the Docker host.
CLEARML_WEB_PORT=8080
CLEARML_API_PORT=8008
CLEARML_FILE_PORT=8081

# Public URLs handed to the UI / SDK.
CLEARML_WEB_EXTERNAL_URL=http://localhost:8080
CLEARML_API_EXTERNAL_URL=http://localhost:8008
CLEARML_FILESERVER_URL=http://localhost:8081
CLEARML_SECURE_HOST=http://localhost:8080

# Elasticsearch JVM heap. Reduce to -Xms512m -Xmx512m on small hosts.
CLEARML_ES_JAVA_OPTS=-Xms1g -Xmx1g
